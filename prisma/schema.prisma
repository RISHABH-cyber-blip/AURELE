// AURELE — database schema
// Relational structure: Brand -> Product -> ProductVariant (this is where stock lives)
// See project notes: this avoids repeating product data per color/strap combo,
// and lets stock/out-of-stock be tracked per variant, not per product.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Supabase Postgres
  url      = env("DATABASE_URL")
}

// ───────────────────────── Catalog ─────────────────────────

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logoUrl     String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique // "Men's", "Women's", "Unisex"
  slug     String    @unique
  products Product[]
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  style       WatchStyle?      // analog / digital / chronograph / etc.
  basePrice   Decimal          @db.Decimal(10, 2)
  currency    String           @default("USD")

  brand       Brand            @relation(fields: [brandId], references: [id])
  brandId     String
  category    Category         @relation(fields: [categoryId], references: [id])
  categoryId  String

  variants    ProductVariant[]
  images      ProductImage[]
  reviews     Review[]

  isPublished Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([brandId])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  position  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

// The sellable unit. Stock, price overrides, and SKU all live here —
// NOT on Product — because "Fossil Gen 6" in black vs silver are
// different purchasable items with independent stock.
model ProductVariant {
  id             String      @id @default(cuid())
  sku            String      @unique
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId      String

  dialColor      String?
  strapMaterial  StrapMaterial?
  size           String?     // e.g. "38mm", "42mm"

  priceOverride  Decimal?    @db.Decimal(10, 2) // null = use product.basePrice
  stockQuantity  Int         @default(0)
  lowStockAt     Int         @default(3)         // threshold for "Only X left" UI
  status         VariantStatus @default(ACTIVE)

  orderItems     OrderItem[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([productId])
}

enum WatchStyle {
  ANALOG
  DIGITAL
  CHRONOGRAPH
  MULTI_FUNCTION
  AUTOMATIC
  SOLAR
  MECHANICAL
}

enum StrapMaterial {
  METAL
  LEATHER
  CERAMIC
  MESH
  RESIN
  SILICONE
}

enum VariantStatus {
  ACTIVE
  DISCONTINUED     // hidden from shop, kept for order history
  TEMP_OUT_OF_STOCK // shown, but not purchasable
}

// ───────────────────────── Users & Reviews ─────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  // Supabase Auth manages the actual credentials; this row mirrors
  // the auth.users id for relational joins with orders/wishlist.
  supabaseId    String     @unique

  addresses     Address[]
  orders        Order[]
  wishlistItems WishlistItem[]
  reviews       Review[]

  createdAt     DateTime   @default(now())
}

model Address {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  fullName   String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String
  phone      String?
  isDefault  Boolean  @default(false)

  orders     Order[]
}

model WishlistItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  rating    Int      // 1-5
  title     String?
  body      String?
  createdAt DateTime @default(now())

  @@index([productId])
}

// ───────────────────────── Orders ─────────────────────────

model Order {
  id              String      @id @default(cuid())
  user            User?       @relation(fields: [userId], references: [id])
  userId          String?     // nullable: guest checkout allowed

  guestEmail      String?     // used when userId is null

  status          OrderStatus @default(PENDING)
  items           OrderItem[]

  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")

  shippingAddress Address?    @relation(fields: [addressId], references: [id])
  addressId       String?

  stripePaymentIntentId String? @unique
  stripeSessionId       String? @unique

  trackingNumber  String?
  carrier         String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              String         @id @default(cuid())
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  variantId       String

  quantity        Int
  priceAtPurchase Decimal        @db.Decimal(10, 2) // snapshot — price may change later

  @@index([orderId])
  @@index([variantId])
}

enum OrderStatus {
  PENDING     // created, awaiting payment confirmation
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
